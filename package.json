{
  "name": "dulcemar",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "install:all": "npm install && cd apps/api && npm install && cd ../web && npm install",
    "prisma:generate": "cd apps/api && npx prisma generate --schema ./src/prisma/schema.prisma",
    "prisma:migrate": "cd apps/api && npx prisma migrate dev --schema ./src/prisma/schema.prisma"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "all": "^0.0.0"
  }
}
